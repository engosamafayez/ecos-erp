  CONSTRAINT `chk_allocation_decisions_actor_type` CHECK ((`actor_type` in (_utf8mb4'system',_utf8mb4'dispatcher',_utf8mb4'driver'))),
  CONSTRAINT `chk_allocation_decisions_quantity_after` CHECK ((`quantity_after` >= 0)),
  CONSTRAINT `chk_allocation_decisions_quantity_before` CHECK ((`quantity_before` >= 0)),
  CONSTRAINT `chk_allocation_decisions_revision_number` CHECK ((`revision_number` >= 1))
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
