CREATE TABLE `vehicle_shift_reconciliation_lines` (
  `id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `company_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `reconciliation_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `vehicle_inventory_item_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `product_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `sku_snapshot` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `quantity_loaded` decimal(18,4) NOT NULL,
  `quantity_delivered` decimal(18,4) NOT NULL,
  `quantity_returned_expected` decimal(18,4) NOT NULL,
  `quantity_returned_actual` decimal(18,4) NOT NULL DEFAULT '0.0000',
  `variance` decimal(18,4) NOT NULL DEFAULT '0.0000',
  `variance_resolution` varchar(50) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `resolution_notes` text COLLATE utf8mb4_unicode_ci,
  `resolved_by` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `resolved_at` timestamp NULL DEFAULT NULL,
  `created_at` timestamp NULL DEFAULT NULL,
  `updated_at` timestamp NULL DEFAULT NULL,
  `created_by` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `updated_by` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  PRIMARY KEY (`id`),
  KEY `fk_vsrl_vehicle_inv_item` (`vehicle_inventory_item_id`),
  KEY `idx_recon_lines_reconciliation_id` (`reconciliation_id`),
  CONSTRAINT `fk_vsrl_vehicle_inv_item` FOREIGN KEY (`vehicle_inventory_item_id`) REFERENCES `vehicle_inventory_items` (`id`) ON DELETE RESTRICT,
  CONSTRAINT `vehicle_shift_reconciliation_lines_reconciliation_id_foreign` FOREIGN KEY (`reconciliation_id`) REFERENCES `vehicle_shift_reconciliations` (`id`) ON DELETE RESTRICT,
  CONSTRAINT `chk_vehicle_shift_recon_lines_quantities` CHECK (((`quantity_loaded` >= 0) and (`quantity_delivered` >= 0) and (`quantity_returned_expected` >= 0) and (`quantity_returned_actual` >= 0))),
  CONSTRAINT `chk_vehicle_shift_recon_lines_variance_resolution` CHECK (((`variance_resolution` is null) or (`variance_resolution` in (_utf8mb4'balanced',_utf8mb4'late_confirmed',_utf8mb4'written_off',_utf8mb4'under_investigation'))))
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
