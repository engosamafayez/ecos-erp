CREATE TABLE `vehicle_plans` (
  `id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `company_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `operational_date` date NOT NULL,
  `plan_number` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL,
  `geography_group_id` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `shipping_company_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `zone_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `governorate_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `status` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL,
  `distribution_policy` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT 'round_robin_weight',
  `version` int NOT NULL DEFAULT '1',
  `superseded_by_id` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `slots_count` int NOT NULL DEFAULT '0',
  `orders_count` int NOT NULL DEFAULT '0',
  `total_weight_kg` decimal(18,4) NOT NULL DEFAULT '0.0000',
  `total_volume_m3` decimal(18,4) NOT NULL DEFAULT '0.0000',
  `proposed_at` timestamp NULL DEFAULT NULL,
  `proposed_by` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `approved_at` timestamp NULL DEFAULT NULL,
  `approved_by` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `cancelled_at` timestamp NULL DEFAULT NULL,
  `cancelled_by` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `cancellation_reason` text COLLATE utf8mb4_unicode_ci,
  `replan_trigger` varchar(100) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `notes` text COLLATE utf8mb4_unicode_ci,
  `created_at` timestamp NULL DEFAULT NULL,
  `updated_at` timestamp NULL DEFAULT NULL,
  `created_by` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `updated_by` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `uq_vehicle_plans_company_plan_number` (`company_id`,`plan_number`),
  KEY `idx_vehicle_plans_company_id` (`company_id`),
  KEY `idx_vehicle_plans_company_status` (`company_id`,`status`),
  KEY `idx_vehicle_plans_company_date` (`company_id`,`operational_date`),
  KEY `idx_vehicle_plans_shipping_company_id` (`shipping_company_id`),
  KEY `idx_vehicle_plans_zone_id` (`zone_id`),
  CONSTRAINT `vehicle_plans_company_id_foreign` FOREIGN KEY (`company_id`) REFERENCES `companies` (`id`) ON DELETE RESTRICT,
  CONSTRAINT `chk_vehicle_plans_distribution_policy` CHECK ((`distribution_policy` in (_utf8mb4'round_robin_weight',_utf8mb4'geographic_proximity',_utf8mb4'order_priority',_utf8mb4'fifo'))),
  CONSTRAINT `chk_vehicle_plans_replan_trigger` CHECK (((`replan_trigger` is null) or (`replan_trigger` in (_utf8mb4'vehicle_breakdown',_utf8mb4'driver_change',_utf8mb4'extra_vehicle',_utf8mb4'late_orders',_utf8mb4'rush_orders',_utf8mb4'route_change',_utf8mb4'manual_replan',_utf8mb4'automatic_replan')))),
  CONSTRAINT `chk_vehicle_plans_status` CHECK ((`status` in (_utf8mb4'calculating',_utf8mb4'proposed',_utf8mb4'approved',_utf8mb4'loading',_utf8mb4'dispatched',_utf8mb4'completed',_utf8mb4'cancelled',_utf8mb4'superseded'))),
  CONSTRAINT `chk_vehicle_plans_total_volume_m3` CHECK ((`total_volume_m3` >= 0)),
  CONSTRAINT `chk_vehicle_plans_total_weight_kg` CHECK ((`total_weight_kg` >= 0)),
  CONSTRAINT `chk_vehicle_plans_version` CHECK ((`version` >= 1))
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
