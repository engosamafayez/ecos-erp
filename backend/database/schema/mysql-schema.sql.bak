  `vehicle_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `driver_assignment_id` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `operational_date` date NOT NULL,
  `status` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT 'open',
  `reconciled_by` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `approved_by` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `has_variance` tinyint(1) NOT NULL DEFAULT '0',
  `variance_notes` text COLLATE utf8mb4_unicode_ci,
  `total_quantity_loaded` decimal(18,4) NOT NULL DEFAULT '0.0000',
  `total_quantity_delivered` decimal(18,4) NOT NULL DEFAULT '0.0000',
  `total_quantity_returned` decimal(18,4) NOT NULL DEFAULT '0.0000',
  `total_variance` decimal(18,4) NOT NULL DEFAULT '0.0000',
  `config_version_id` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `opened_at` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `completed_at` timestamp NULL DEFAULT NULL,
  `created_at` timestamp NULL DEFAULT NULL,
  `updated_at` timestamp NULL DEFAULT NULL,
  `created_by` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `updated_by` char(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `vehicle_shift_reconciliations_vehicle_assignment_id_unique` (`vehicle_assignment_id`),
  KEY `vehicle_shift_reconciliations_driver_assignment_id_foreign` (`driver_assignment_id`),
  KEY `idx_reconciliations_assignment_id` (`vehicle_assignment_id`),
  KEY `idx_reconciliations_company_status` (`company_id`,`status`),
  CONSTRAINT `vehicle_shift_reconciliations_driver_assignment_id_foreign` FOREIGN KEY (`driver_assignment_id`) REFERENCES `driver_assignments` (`id`) ON DELETE RESTRICT,
  CONSTRAINT `vehicle_shift_reconciliations_vehicle_assignment_id_foreign` FOREIGN KEY (`vehicle_assignment_id`) REFERENCES `vehicle_assignments` (`id`) ON DELETE RESTRICT,
  CONSTRAINT `chk_vehicle_shift_reconciliations_quantities` CHECK (((`total_quantity_loaded` >= 0) and (`total_quantity_delivered` >= 0) and (`total_quantity_returned` >= 0))),
  CONSTRAINT `chk_vehicle_shift_reconciliations_status` CHECK ((`status` in (_utf8mb4'open',_utf8mb4'completed',_utf8mb4'approved',_utf8mb4'disputed')))
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
