  CONSTRAINT `chk_allocation_records_priority_rank` CHECK ((`priority_rank` >= 1)),
  CONSTRAINT `chk_allocation_records_quantity_allocated` CHECK ((`quantity_allocated` >= 0)),
  CONSTRAINT `chk_allocation_records_quantity_delivered` CHECK ((`quantity_delivered` >= 0)),
  CONSTRAINT `chk_allocation_records_quantity_requested` CHECK ((`quantity_requested` > 0)),
  CONSTRAINT `chk_allocation_records_status` CHECK ((`status` in (_utf8mb4'allocated',_utf8mb4'confirmed',_utf8mb4'in_delivery',_utf8mb4'delivered',_utf8mb4'partial_delivery',_utf8mb4'failed',_utf8mb4'cancelled')))
