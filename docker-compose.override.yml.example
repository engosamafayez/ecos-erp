# =============================================================================
# ECOS ERP — Development overrides
#
# Docker Compose automatically merges this file with docker-compose.yml when
# you run `docker compose up` (without -f) on a developer machine.
#
# Purpose: restore source bind-mounts so code changes are reflected
# immediately without rebuilding the image after every edit.
#
# Rules:
#   This file MUST NOT be present on production servers.
#   deploy.sh uses `docker compose -f docker-compose.yml` to explicitly
#   exclude this file. The deploy script will abort if it detects this file.
# =============================================================================

services:

  # ---------------------------------------------------------------------------
  # app — bind-mount backend source for live PHP reload
  #
  # The entire backend/ directory replaces the image's /var/www/html.
  # This means vendor/, public/app, and bootstrap/cache/ are all sourced
  # from the host filesystem instead of the image layer.
  #
  # Requirements:
  #   • backend/vendor/ must exist locally (run `composer install` locally or
  #     copy from image: docker cp ecos-app:/var/www/html/vendor backend/)
  #   • backend/public/app/ must exist locally (run `npm run build` in frontend/)
  # ---------------------------------------------------------------------------
  app:
    volumes:
      - ./backend:/var/www/html

  # ---------------------------------------------------------------------------
  # nginx — use stock image + public/ bind-mount for dev
  #
  # In development the Vite dev server (port 5173) handles HMR for the SPA.
  # The stock nginx image serves backend/public/ directly without a custom build.
  # ---------------------------------------------------------------------------
  nginx:
    image: nginx:1.27-alpine
    build: !reset null    # cancel the Stage 4 build — stock image is enough in dev
    volumes:
      - ./backend/public:/var/www/html/public:ro
      - ./docker/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
