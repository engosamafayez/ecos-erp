# =============================================================================
# ECOS ERP — Docker build context exclusions
#
# Goal: send only what each build stage actually needs.
# Every excluded path reduces build time and prevents secret/cache leakage.
# =============================================================================

# Version control
.git
.gitignore
.gitattributes

# Editor / OS
.idea
.vscode
.nova
.zed
.DS_Store
Thumbs.db

# Documentation (never inside an image)
docs/
*.md

# =============================================================================
# Backend exclusions
# =============================================================================

# Vendor is resolved in Stage 1 (composer builder) and COPY'd from there.
# Never let the host vendor/ pollute the build context.
backend/vendor/
backend/node_modules/

# CRITICAL: Bootstrap cache must NEVER be baked into images.
# These files are generated by artisan optimize at runtime and stored in the
# app-cache named volume. If they exist locally they contain dev-only providers
# (e.g. laravel/pail) that will cause fatal errors in production.
backend/bootstrap/cache/*.php

# Public build artifacts — built in Stage 2 and COPY'd from there.
backend/public/app/
backend/public/build/
backend/public/hot

# The storage:link symlink is re-created by the entrypoint; never copy it.
backend/public/storage

# Runtime storage — populated at container start; never in image
backend/storage/logs/*
backend/storage/framework/cache/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*

# Secrets — always injected via env_file at runtime
backend/.env
backend/.env.*

# Dev tooling
backend/.phpunit.cache/
backend/.phpunit.result.cache
backend/auth.json

# =============================================================================
# Frontend exclusions
# =============================================================================

# Node modules resolved in Stage 2 (frontend builder)
frontend/node_modules/
frontend/dist/
frontend/*.local

# =============================================================================
# Repository-level dev artifacts
# =============================================================================
docker-compose.override.yml
deploy.sh
scripts/
*.sh
