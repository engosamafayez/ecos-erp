# ===== ECOS ERP — repository ignores =====

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
.nova/
.zed/
.claude/

# Logs
*.log

# Environment
.env
.env.backup
.env.production
backend/.env

# Docker Compose developer override — never committed; copy from .example to use.
# Production servers must never have this file (deploy.sh aborts if it exists).
docker-compose.override.yml

# PHP / Laravel (backend)
backend/vendor/
backend/node_modules/
backend/public/build/
backend/public/hot
backend/public/storage
backend/public/app/
backend/storage/*.key
backend/storage/pail
backend/.phpunit.result.cache
backend/.phpunit.cache/
backend/auth.json
backend/_ide_helper.php

# Frontend (React / Vite)
frontend/node_modules/
frontend/dist/
frontend/*.local

# Node (root, if any)
/node_modules/

# Test coverage output
coverage/
.nyc_output/
frontend/coverage/
backend/coverage/

# Backup / temp files
*.bak
*.backup
*.orig
*.tmp

# Laravel debug helpers (never commit generated helpers)
backend/_ide_helper_models.php

# Docker runtime state
.docker/

# Scratchpad / one-off scripts (dev-only, never tracked)
backend/*.sh
